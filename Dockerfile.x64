# syntax=docker/dockerfile:1.6
#
# Builds Emgu CV's libcvextern.so for linux-x64 on Debian 10 (Buster, glibc 2.28 floor).
# The resulting binary loads on Debian 10+, Ubuntu 18.10+, Linux Mint 19.3+, RHEL 8+, etc.
# Aligned with the arm64/armhf builds — all three targets share the same glibc 2.28 floor.
#
# Usage (from this directory):
#   docker build -f Dockerfile.x64 --output type=local,dest=./out/linux-x64 .
#
# Output: ./out/linux-x64/libcvextern.so
# Build time: 45-90 min on a fast 8-core box; longer on smaller machines.

FROM debian:buster AS builder

# Tag in the emgucv repo. The NuGet revision .5764 is package-only; the git tag is 4.12.0.
ARG EMGU_TAG=4.12.0
# Build profile passed to Emgu's cmake_configure: full | core | mini
ARG BUILD_TYPE=full
# Parallel make jobs (default: all cores)
ARG JOBS=
# Set to 1 to disable FFmpeg/GStreamer to dodge libavcodec.so version pinning across Ubuntu releases.
# Recommended ON for portable AgentDVR builds since videoio isn't used.
ARG PORTABLE=1

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Etc/UTC \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

# Use bash with pipefail for all RUN steps. Buster's default /bin/sh is dash
# 0.5.10.2, which predates pipefail support (added in dash 0.5.11, mid-2020).
# Without pipefail, the build RUN's `cmake_configure | tee | tail` pipeline
# returned tail's exit code (always 0), silently masking real compile errors.
# bash is a superset of POSIX sh — other RUN steps work unchanged.
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Fix apt sources — Buster (Debian 10) reached EOL June 2024 and moved to the archive.
# Disable Valid-Until check because the archived Release files have expired dates.
RUN printf 'deb http://archive.debian.org/debian buster main\ndeb http://archive.debian.org/debian-security buster/updates main\n' \
      > /etc/apt/sources.list \
 && printf 'Acquire::Check-Valid-Until "false";\n' \
      > /etc/apt/apt.conf.d/99no-check-valid-until

# Stub files used by the PORTABLE patch step (see RUN block lower down).
COPY patches/ /patches/

# ---- Build dependencies ---------------------------------------------------
# Mirror of Emgu's platforms/debian/bookworm/apt_install_dependency, transposed to Buster.
# Differences from Bookworm:
#   libdc1394-dev   -> libdc1394-22-dev  (renamed in Bookworm)
#   libfreetype-dev -> libfreetype6-dev  (libfreetype-dev alias added in Bookworm)
#   libvtk9-dev     -> libvtk6-dev       (VTK9 first appeared in Bullseye; Buster ships VTK6)
#   libopengl-dev   -> libgl1-mesa-dev   (libopengl-dev split not backported to Buster)
# ocl-icd-dev omitted: PORTABLE=1 disables OpenCL; package name also differs in Buster.
# Buster ships cmake 3.13; EmguCV 4.12 requires 3.16 (upgraded via pip3 below).
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates curl wget gnupg lsb-release \
      git build-essential cmake pkg-config file binutils python3 ccache \
      libgtk-3-dev libgstreamer1.0-dev libgstreamer-plugins-base1.0-dev \
      libavcodec-dev libswscale-dev libavformat-dev libdc1394-22-dev libv4l-dev \
      libgl1-mesa-dev freeglut3-dev libgeotiff-dev libusb-1.0-0-dev \
      libvtk6-dev libfreetype6-dev libharfbuzz-dev qtbase5-dev libeigen3-dev \
      libgflags-dev libgoogle-glog-dev liblapacke-dev libva-dev \
 && rm -rf /var/lib/apt/lists/*

# ---- ccache configuration -------------------------------------------------
# Prepend ccache's compiler symlinks dir to PATH so cmake's auto-detection finds
# `/usr/lib/ccache/gcc` and `/usr/lib/ccache/g++` first — they transparently wrap
# the real compiler. CCACHE_COMPILERCHECK=content hashes the compiler binary
# (default is mtime, which is unreliable across Docker layer rebuilds where the
# gcc binary's mtime resets even though its content is identical).
# CCACHE_DIR defaults to /root/.ccache — matches the BuildKit cache mount target
# in the build RUN below.
ENV PATH="/usr/lib/ccache:${PATH}" \
    CCACHE_COMPILERCHECK=content \
    CCACHE_MAXSIZE=10G \
    CCACHE_SLOPPINESS=time_macros,include_file_mtime,include_file_ctime

# dotnet-sdk-8.0 is REQUIRED by Emgu's CMake (FindCSharp emits FATAL_ERROR otherwise),
# even for a native-only build. Microsoft's Debian apt feed doesn't carry x64 Buster packages,
# so we use dotnet-install.sh — the same approach as Dockerfile.arm64 and Dockerfile.armhf.
RUN wget -q https://dot.net/v1/dotnet-install.sh -O /tmp/dotnet-install.sh \
 && chmod +x /tmp/dotnet-install.sh \
 && /tmp/dotnet-install.sh --channel 8.0 --install-dir /usr/share/dotnet \
 && ln -sf /usr/share/dotnet/dotnet /usr/bin/dotnet \
 && rm /tmp/dotnet-install.sh \
 && dotnet --version

# Buster ships cmake 3.13 but EmguCV 4.12 requires cmake >= 3.16.
# Download cmake 3.28 binary from cmake.org (glibc 2.17 floor — runs fine on Buster).
# Avoids pip/Python version issues: cmake 4.x has no Python 3.7 wheels (Buster) and
# building from source is a circular dependency.
RUN CMAKE_VER=3.28.0 \
 && wget -q "https://github.com/Kitware/CMake/releases/download/v${CMAKE_VER}/cmake-${CMAKE_VER}-linux-x86_64.tar.gz" \
 && tar xf cmake-${CMAKE_VER}-linux-x86_64.tar.gz -C /usr/local --strip-components=1 \
 && rm cmake-${CMAKE_VER}-linux-x86_64.tar.gz \
 && cmake --version

# Mono deliberately omitted. FindCSharp.cmake checks for `dotnet` first, mono is only a
# legacy fallback. Skipping it shaves several hundred MB off the build image and keeps all
# three Dockerfiles (x64, arm64, armhf) consistent.

# ---- Source ---------------------------------------------------------------
WORKDIR /work
RUN git clone --depth 1 --branch ${EMGU_TAG} https://github.com/emgucv/emgucv.git emgucv
WORKDIR /work/emgucv

# Pull only the submodules the build needs (skip openvino + depthai which are huge & optional).
# --depth 1 keeps the per-submodule clone shallow.
RUN git submodule update --init --depth 1 --recursive -- \
      opencv \
      opencv_contrib \
      opencv_extra \
      eigen \
      harfbuzz \
      hdf5 \
      vtk \
      3rdParty/freetype2 \
      Emgu.CV.Extern/tesseract/libtesseract/tesseract-ocr.git \
      Emgu.CV.Extern/tesseract/libtesseract/leptonica/leptonica.git

# ---- Configure & build ----------------------------------------------------
# We run Emgu's stock configure script (platforms/debian/bookworm/cmake_configure).
# It's distro-version-agnostic — only the apt deps differ across distro releases.

WORKDIR /work/emgucv/platforms/debian/bookworm

# AgentDVR-minimal build: strip OpenCV to only the modules AgentDVR uses + disable unused features.
# BUILD_LIST whitelist: core, imgproc, calib3d, features2d, flann, video, objdetect, tracking, plot, bgsegm.
#
# CRITICAL: WITH_*=OFF flags below are what actually prevent unwanted runtime .so dependencies.
# BUILD_*=FALSE only controls whether OpenCV builds its bundled copy of a 3rd-party lib;
# without WITH_*=OFF the build will auto-detect and dynamically link the system version,
# which is how libtiff.so.5 / libva.so.2 deps crept in previously (broke on Ubuntu 24.04
# which ships libtiff6 instead of libtiff5). Goal: libcvextern.so depends ONLY on libc,
# libstdc++, libgcc_s, libm, libpthread, librt, libdl, libz (all universal across distros).
#
# Disables that kill unused runtime .so deps:
#   FFmpeg / GStreamer / V4L            -> libavcodec.so.X etc, hard-pinned per Ubuntu release
#   HDF5 / opencv_hdf                   -> libhdf5_serial.so.103 dep gone
#   VTK                                 -> libvtk*.so.X deps gone
#   GDAL / TIFF / EMGU_CV_WITH_TIFF     -> libgeotiff.so.5, libtiff.so.5 deps gone
#   JPEG / PNG / WEBP / OPENEXR / JASPER / OPENJPEG -> all imgcodecs format libs (module disabled anyway)
#   VA / VA_INTEL                       -> libva.so.2, libva-drm.so.2 deps gone
#   1394                                -> libdc1394 dep gone
#   FREETYPE / harfbuzz                 -> libfreetype.so, libharfbuzz.so deps gone
#   GTK / QT / OPENGL                   -> no highgui module anyway
#   PROTOBUF                            -> DNN module isn't built; no libprotobuf dep
#   ADE                                 -> gapi module isn't built
#   OBSENSOR                            -> Orbbec videoio backend (videoio not built)
#   TESSERACT / FREETYPE                -> Emgu's vendored builds skipped
# Variables inside CONTRIB_OPTION, TESSERACT_OPTION, FREETYPE_OPTION are flipped via separate seds
# because cmake's last-wins rule would otherwise override our injected flags.
#
# Emgu bug fix: stitching_c.h and xfeatures2d/nonfree_c.h declare `class Feature2D {};` (empty
# class DEFINITION) as a stub when their parent module is disabled. This collides with the real
# `class Feature2D : public Algorithm { ... }` from features2d.hpp when a generated header like
# vector_CameraParams.h includes both in the same translation unit.
#
# Naive fix (delete the stub) fails because Emgu globs wrapper .cpp files unconditionally —
# nonfree_c.cpp and stitching_c.cpp DO get compiled even when their modules aren't in BUILD_LIST,
# and they reference cv::Feature2D in function signatures (`cv::Feature2D*` / `cv::Feature2D**`).
# Delete the stub and those .cpp files fail with "Feature2D has not been declared".
#
# Correct fix: substitute the empty-class DEFINITION (`class Feature2D {};`) with a forward
# DECLARATION (`class Feature2D;`). Forward decls are compatible with the real definition (C++
# allows forward decl + full def in the same TU), and pointer-typed function signatures only
# need a forward decl to compile.
RUN if [ "${PORTABLE}" = "1" ]; then \
      sed -i 's|-DBUILD_TESTS:BOOL=FALSE|-DBUILD_TESTS:BOOL=FALSE -DBUILD_LIST=core,imgproc,calib3d,features2d,flann,video,objdetect,tracking,plot,bgsegm -DWITH_FFMPEG:BOOL=OFF -DWITH_GSTREAMER:BOOL=OFF -DWITH_V4L:BOOL=OFF -DWITH_LIBV4L:BOOL=OFF -DWITH_HDF5:BOOL=OFF -DWITH_VTK:BOOL=OFF -DWITH_GDAL:BOOL=OFF -DWITH_TIFF:BOOL=OFF -DWITH_JPEG:BOOL=OFF -DWITH_PNG:BOOL=OFF -DWITH_WEBP:BOOL=OFF -DWITH_OPENEXR:BOOL=OFF -DWITH_JASPER:BOOL=OFF -DWITH_OPENJPEG:BOOL=OFF -DWITH_VA:BOOL=OFF -DWITH_VA_INTEL:BOOL=OFF -DWITH_1394:BOOL=OFF -DWITH_FREETYPE:BOOL=OFF -DWITH_GTK:BOOL=OFF -DWITH_GTK_2_X:BOOL=OFF -DWITH_QT:BOOL=OFF -DWITH_OPENGL:BOOL=OFF -DWITH_PROTOBUF:BOOL=OFF -DWITH_ADE:BOOL=OFF -DWITH_OBSENSOR:BOOL=OFF -DBUILD_opencv_hdf:BOOL=OFF -DEMGU_CV_WITH_TIFF:BOOL=FALSE -DWITH_IPP:BOOL=OFF -DWITH_OPENCL:BOOL=OFF -DWITH_LAPACK:BOOL=OFF -DWITH_TBB:BOOL=OFF -DWITH_QUIRC:BOOL=OFF -DWITH_ITT:BOOL=OFF -DBUILD_IPP_IW:BOOL=OFF -DBUILD_ITT:BOOL=OFF -DCPU_BASELINE=SSE3 -DCPU_DISPATCH="SSSE3,SSE4_1,POPCNT,SSE4_2,AVX,FP16,AVX2,AVX_512F,AVX512_SKX"|' cmake_configure ; \
      sed -i 's|-DBUILD_PNG:BOOL=TRUE|-DBUILD_PNG:BOOL=FALSE|g; s|-DBUILD_JPEG:BOOL=TRUE|-DBUILD_JPEG:BOOL=FALSE|g; s|-DBUILD_TIFF:BOOL=TRUE|-DBUILD_TIFF:BOOL=FALSE|g; s|-DBUILD_WEBP:BOOL=TRUE|-DBUILD_WEBP:BOOL=FALSE|g; s|-DBUILD_JASPER:BOOL=TRUE|-DBUILD_JASPER:BOOL=FALSE|g; s|-DBUILD_OPENEXR:BOOL=TRUE|-DBUILD_OPENEXR:BOOL=FALSE|g' cmake_configure ; \
      sed -i 's|-DWITH_VTK:BOOL=TRUE|-DWITH_VTK:BOOL=FALSE|g; s|-DWITH_GSTREAMER:BOOL=TRUE|-DWITH_GSTREAMER:BOOL=FALSE|g' cmake_configure ; \
      sed -i 's|EMGU_CV_WITH_TESSERACT:BOOL=TRUE|EMGU_CV_WITH_TESSERACT:BOOL=FALSE|g; s|EMGU_CV_WITH_FREETYPE:BOOL=TRUE|EMGU_CV_WITH_FREETYPE:BOOL=FALSE|g' cmake_configure ; \
      sed -i 's|class Feature2D {};|class Feature2D;|g' /work/emgucv/Emgu.CV.Extern/stitching/stitching_c.h ; \
      sed -i 's|class Feature2D {};|class Feature2D;|g' /work/emgucv/Emgu.CV.Extern/xfeatures2d/nonfree_c.h ; \
      \
      # Overlay the stub core_cuda_c.cpp. Original calls cv::cuda::DeviceInfo ctor which \
      # CV_Asserts when device count is 0 (which it always is without WITH_CUDA), and that \
      # assertion fires through the OpenCV error handler → cv::Exception → unhandled native \
      # exception → SIGABRT. CV_Assert is independent of throw_no_cuda so our earlier patches \
      # don't catch it. The stub replaces every function with a safe-default returning no-op. \
      cp /patches/core_cuda_c.cpp.stub /work/emgucv/Emgu.CV.Extern/core/core_cuda_c.cpp ; \
      echo "Replaced Emgu.CV.Extern/core/core_cuda_c.cpp with safe stub." ; \
      \
      # Remove the imgcodecs Emgu wrapper subdir entirely — its imgcodecs_c_extra.cpp \
      # references cv::Animation which only exists in the (disabled) imgcodecs module. \
      # No other Emgu wrapper imports imgcodecs headers, and no CREATE_OCV_CLASS_PROPERTY \
      # call regenerates files in imgcodecs/, so the rm sticks. AgentDVR uses .NET for \
      # image I/O, not OpenCV. \
      rm -rf /work/emgucv/Emgu.CV.Extern/imgcodecs ; \
      \
      # CUDA defensive patch: cuda* wrapper subdirs stay in place (3 CREATE_OCV_CLASS_PROPERTY \
      # calls regenerate property files in cuda*/, so rm -rf doesn't work). Instead, patch \
      # the throw_no_cuda* stub functions to be no-ops. \
      # \
      # WHY: when AgentDVR runs with ONNX Runtime's CUDA EP, something in the code path calls \
      # a cv::cuda::* operation without first checking CudaInvoke.HasCuda. The wrapper then \
      # calls CV_Error() which throws cv::Exception. .NET on Linux can't reliably propagate \
      # C++ exceptions through P/Invoke — it crashes the process. \
      # \
      # The patch: remove CV_NORETURN attribute and replace the CV_Error body with a no-op. \
      # Now the stubs return silently instead of throwing. Non-void functions fall off without \
      # a return statement (UB, returns garbage from the return register), but for AgentDVR's \
      # use case the offending code path is expected to be guarded by HasCuda anyway — the \
      # patch is defense-in-depth for the unguarded case so the process doesn't crash. \
      find /work/emgucv/Emgu.CV.Extern -type d -name 'cuda*' | while read d; do \
        for h in "$d"/*_c.h; do \
          [ -f "$h" ] || continue; \
          sed -i 's|CV_NORETURN ||g; s|CV_Error([^)]*);|/* defensive no-op: see Dockerfile.x64 */;|g' "$h"; \
        done; \
      done ; \
      echo "Patched Emgu cuda throw_no_cuda* stubs to silent no-ops." ; \
      \
      # ALSO patch OpenCV's INTERNAL throw_no_cuda() in private.cuda.hpp. This is the one \
      # actually firing in production: Emgu's core_cuda_c.cpp (cudaSetDevice, cudaGetDevice) \
      # directly invokes cv::cuda::setDevice / cv::cuda::getDevice in OpenCV core, which call \
      # this internal throw_no_cuda(). The Emgu layer patch alone doesn't catch this path. \
      # Both definitions (HAVE_CUDA undef and the HAVE_CUDA-defined fallback) get neutralized. \
      sed -i 's|CV_NORETURN void throw_no_cuda() { CV_Error([^)]*); }|void throw_no_cuda() { /* defensive no-op */ }|g' \
        /work/emgucv/opencv/modules/core/include/opencv2/core/private.cuda.hpp ; \
      echo "Patched OpenCV internal throw_no_cuda() in opencv/modules/core/include/opencv2/core/private.cuda.hpp." ; \
      \
      echo "AgentDVR-minimal build: BUILD_LIST applied; unused features disabled; Feature2D stubs forward-decl'd; imgcodecs wrapper removed; cuda throws neutralized." ; \
    fi

# Run configure (which also kicks off `make`). MAKEFLAGS must be set inside RUN so $(nproc) expands.
# Tee full output to /tmp/emgu_build.log AND stdout so CI captures everything.
# ccache is installed and on PATH but no persistent mount — would only help on
# local iterative builds, which aren't the expected usage pattern.
RUN if [ -n "${JOBS}" ]; then PARALLEL="${JOBS}"; else PARALLEL="$(nproc)"; fi; \
    sed -i "s|--parallel 1|--parallel ${PARALLEL}|g" cmake_configure; \
    export MAKEFLAGS="-j${PARALLEL}"; \
    echo "Building with PARALLEL=${PARALLEL}"; \
    bash ./cmake_configure ${BUILD_TYPE} 2>&1 | tee /tmp/emgu_build.log ; \
    BUILD_RC=$? ; \
    if [ "$BUILD_RC" != "0" ]; then \
      echo "" >&2 ; \
      echo "!!! BUILD FAILED with exit code $BUILD_RC. Scroll up to find the actual error." >&2 ; \
      echo "!!! Full build log is at /tmp/emgu_build.log inside the build container." >&2 ; \
    fi ; \
    exit $BUILD_RC

# ---- Strip + Verify ------------------------------------------------------
# Expected output path is libs/runtimes/linux-x64/native/ when IS_DEBIAN=TRUE.
# If lsb-release detection misfires, the .so may land elsewhere under libs/. Find it
# and relocate to the expected path before strip/verify.
RUN set -e ; \
    EXPECTED=/work/emgucv/libs/runtimes/linux-x64/native ; \
    if [ ! -f "$EXPECTED/libcvextern.so" ]; then \
      FOUND="$(find /work/emgucv/libs -name libcvextern.so -type f 2>/dev/null | head -1)" ; \
      if [ -z "$FOUND" ]; then \
        echo "ERROR: libcvextern.so was not produced anywhere under /work/emgucv/libs" ; \
        find /work/emgucv -name 'libcvextern*' 2>/dev/null | head ; \
        tail -200 /tmp/emgu_build.log ; \
        exit 1 ; \
      fi ; \
      echo "NOTE: libcvextern.so was at $FOUND (not expected path $EXPECTED). Relocating." ; \
      mkdir -p "$EXPECTED" ; \
      cp -p "$FOUND" "$EXPECTED/libcvextern.so" ; \
    fi
WORKDIR /work/emgucv/libs/runtimes/linux-x64/native
# Aggressive strip: remove ALL non-dynamic symbols + debug info.
# --strip-all is safe for shared libraries that don't need their static symbol table
# (which is what AgentDVR ships — runtime only needs the dynamic symbol table).
RUN echo "=== SIZE BEFORE STRIP ===" && ls -lh libcvextern.so && \
    strip --strip-all libcvextern.so && \
    echo "=== SIZE AFTER STRIP ===" && ls -lh libcvextern.so
RUN set -e ; \
    file libcvextern.so ; \
    ls -lh libcvextern.so ; \
    echo "=== GLIBC SYMBOLS REQUIRED (max should be <= 2.28) ===" ; \
    # Wrap the nm|grep pipeline in `set +e` so pipeline failures (e.g. grep \
    # returning 1 when no matches, or nm exiting non-zero on certain stripped \
    # binaries) don't abort the script via the SHELL-level pipefail+set-e. \
    # This is informational; the strict whitelist check below is what matters. \
    set +o pipefail ; set +e ; \
    nm --dynamic --undefined-only libcvextern.so 2>/dev/null \
      | grep -oE 'GLIBC_[0-9.]+' | sort -V | uniq > /tmp/glibc_syms.txt || true ; \
    set -e ; set -o pipefail ; \
    MAX_GLIBC="$(tail -1 /tmp/glibc_syms.txt 2>/dev/null || echo '(none)')" ; \
    echo "Max GLIBC symbol: ${MAX_GLIBC}" ; \
    echo "All GLIBC versions referenced:" ; \
    cat /tmp/glibc_syms.txt 2>/dev/null | sed 's/^/  /' || echo "  (none)" ; \
    echo "=== NEEDED ENTRIES (must be whitelist-only) ===" ; \
    readelf -d libcvextern.so | grep NEEDED ; \
    \
    # Whitelist of allowed dynamic dependencies. These are universally present on every \
    # Linux distribution (glibc base + libstdc++ + zlib). Any NEEDED entry outside this \
    # list means the build picked up an unintended system library (e.g. libtiff5 from \
    # libgeotiff-dev) — that breaks portability across distro versions. \
    ALLOWED='^(libc\.so\.6|libdl\.so\.2|libm\.so\.6|libpthread\.so\.0|librt\.so\.1|libgcc_s\.so\.1|libstdc\+\+\.so\.6|libz\.so\.1)$' ; \
    UNEXPECTED="$(readelf -d libcvextern.so | awk '/NEEDED/ {gsub(/[\[\]]/,"",$NF); print $NF}' | grep -Ev "${ALLOWED}" || true)" ; \
    if [ -n "${UNEXPECTED}" ]; then \
      echo "" ; \
      echo "!!! ERROR: libcvextern.so has unexpected runtime dependencies:" ; \
      echo "${UNEXPECTED}" | sed 's/^/    /' ; \
      echo "" ; \
      echo "These libs are NOT universally available across all target distros and will" ; \
      echo "cause 'failed to load libcvextern.so' at runtime on minimal installs." ; \
      echo "Add the corresponding -DWITH_<NAME>:BOOL=OFF flag to the cmake_configure sed" ; \
      echo "above and rebuild. See the libtiff5 → Ubuntu 24.04 regression for context." ; \
      exit 1 ; \
    fi ; \
    echo "(NEEDED whitelist OK — only portable system libs)" ; \
    \
    echo "=== LDD (missing dependencies should be empty) ===" ; \
    if ldd libcvextern.so | grep "not found" ; then \
      echo "!!! ERROR: unresolved dependencies above" ; exit 1 ; \
    else \
      echo "(no missing libs)" ; \
    fi ; \
    echo "=== EXPORTED SYMBOL COUNT ===" ; \
    nm --dynamic --defined-only libcvextern.so | wc -l

# ---- Export stage (scratch image holding only the artifact) ---------------
FROM scratch AS export
COPY --from=builder /work/emgucv/libs/runtimes/linux-x64/native/libcvextern.so /libcvextern.so
# Also export the build log for postmortem / verification.
COPY --from=builder /tmp/emgu_build.log /emgu_build.log
