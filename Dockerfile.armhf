# syntax=docker/dockerfile:1.6
#
# Builds Emgu CV's libcvextern.so for linux-arm (armv7/armhf) on Debian 10 (Buster, glibc 2.28).
# Output binary loads on Debian 10+ armhf, Raspberry Pi OS Buster+ (32-bit), Ubuntu 18.10+ armhf, etc.
#
# Usage (on an x64/arm64 dev box, requires QEMU + buildx):
#   docker run --privileged --rm tonistiigi/binfmt --install arm
#   docker buildx create --use --name emgucv-armhf 2>/dev/null || true
#   docker buildx build --platform linux/arm/v7 -f Dockerfile.armhf \
#       --output type=local,dest=./out/linux-arm .
#
# Usage (on a real armhf host — much faster):
#   docker build -f Dockerfile.armhf --output type=local,dest=./out/linux-arm .
#
# Output: ./out/linux-arm/libcvextern.so
# Build time via QEMU emulation: 3-8 hours. Native armhf host: ~90-120 min.
#
# .NET RID for 32-bit ARM is "linux-arm". Emgu outputs the .so to:
#   libs/runtimes/linux-arm/native/libcvextern.so  (when IS_DEBIAN=TRUE)

FROM --platform=linux/arm/v7 debian:buster AS builder

ARG EMGU_TAG=4.12.0
ARG BUILD_TYPE=full
ARG JOBS=
ARG PORTABLE=1

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Etc/UTC \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

# Fix apt sources — Buster (Debian 10) reached EOL June 2024 and moved to the archive.
# Disable Valid-Until check because the archived Release files have expired dates.
RUN printf 'deb http://archive.debian.org/debian buster main\ndeb http://archive.debian.org/debian-security buster/updates main\n' \
      > /etc/apt/sources.list \
 && printf 'Acquire::Check-Valid-Until "false";\n' \
      > /etc/apt/apt.conf.d/99no-check-valid-until

# Stub files used by the PORTABLE patch step (see RUN block lower down).
COPY patches/ /patches/

# ---- Build dependencies ---------------------------------------------------
# Same package set as Dockerfile.arm64 (both Debian 10 Buster).
# lsb-release is required — see Dockerfile.arm64 for the detailed explanation.
# Mono omitted for the same reasons as arm64 (QEMU segfault in post-install).
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates curl wget gnupg git lsb-release \
      build-essential cmake pkg-config file binutils python3 \
      libtiff-dev libgeotiff-dev libgtk-3-dev libgstreamer1.0-dev \
      libavcodec-dev libswscale-dev libavformat-dev libopenexr-dev \
      libdc1394-22-dev libv4l-dev libeigen3-dev libgl1-mesa-dev cmake-curses-gui \
      freeglut3-dev libvtk6-dev qtbase5-dev libusb-1.0-0-dev ccache \
      libharfbuzz-dev libfreetype6-dev libgflags-dev libgoogle-glog-dev liblapacke-dev \
 && rm -rf /var/lib/apt/lists/*

# ccache: prepend /usr/lib/ccache to PATH so cmake auto-uses ccache-wrapped gcc/g++.
# See Dockerfile.x64 for full rationale. Especially valuable for armhf under QEMU
# where rebuilds otherwise take 3-8 hours.
ENV PATH="/usr/lib/ccache:${PATH}" \
    CCACHE_COMPILERCHECK=content \
    CCACHE_MAXSIZE=10G \
    CCACHE_SLOPPINESS=time_macros,include_file_mtime,include_file_ctime

# dotnet-sdk-8.0 — download tarball directly from the stable Azure CDN with a pinned version.
# dotnet-install.sh's "latest channel" resolution hits builds.dotnet.microsoft.com which is
# unreachable from inside the QEMU armhf container. Pinning a specific version bypasses that
# lookup entirely and goes straight to the versioned download URL.
# RID for armhf (armv7 hard-float) in .NET terminology is linux-arm.
ARG DOTNET_VER=8.0.407
RUN mkdir -p /usr/share/dotnet \
 && wget -q "https://dotnetcli.azureedge.net/dotnet/Sdk/${DOTNET_VER}/dotnet-sdk-${DOTNET_VER}-linux-arm.tar.gz" \
 && tar xzf dotnet-sdk-${DOTNET_VER}-linux-arm.tar.gz -C /usr/share/dotnet \
 && rm dotnet-sdk-${DOTNET_VER}-linux-arm.tar.gz \
 && ln -sf /usr/share/dotnet/dotnet /usr/bin/dotnet \
 && dotnet --version

# Buster ships cmake 3.13 but EmguCV 4.12 requires cmake >= 3.16.
# cmake.org provides no armhf binary, so build from source via the bootstrap script.
# bootstrap is architecture-agnostic (only needs an existing C/C++ toolchain + make).
# Build time: ~20-40 min native; under QEMU adds roughly 1-2 h to the overall job.
# cmake 3.28 was chosen: same as the arm64/x64 builds, glibc 2.17 floor doesn't apply
# here because we're building it ourselves inside the Buster container.
# -DCMAKE_USE_OPENSSL=OFF: avoids needing libssl-dev headers; cmake's built-in file()
# download (used for FetchContent) still works via wget/curl as a fallback.
RUN CMAKE_VER=3.28.0 \
 && wget -q "https://github.com/Kitware/CMake/releases/download/v${CMAKE_VER}/cmake-${CMAKE_VER}.tar.gz" \
 && tar xf cmake-${CMAKE_VER}.tar.gz \
 && cd cmake-${CMAKE_VER} \
 && ./bootstrap --parallel=$(nproc) -- -DCMAKE_USE_OPENSSL=OFF \
 && make -j$(nproc) \
 && make install \
 && cd / && rm -rf cmake-${CMAKE_VER} cmake-${CMAKE_VER}.tar.gz \
 && cmake --version

# ---- Source ---------------------------------------------------------------
WORKDIR /work
RUN git clone --depth 1 --branch ${EMGU_TAG} https://github.com/emgucv/emgucv.git emgucv
WORKDIR /work/emgucv

RUN git submodule update --init --depth 1 --recursive -- \
      opencv \
      opencv_contrib \
      opencv_extra \
      eigen \
      harfbuzz \
      hdf5 \
      vtk \
      3rdParty/freetype2 \
      Emgu.CV.Extern/tesseract/libtesseract/tesseract-ocr.git \
      Emgu.CV.Extern/tesseract/libtesseract/leptonica/leptonica.git

# ---- Configure & build ----------------------------------------------------
WORKDIR /work/emgucv/platforms/debian/bookworm

# AgentDVR-minimal build: same module strip + portability disables as arm64.
# See Dockerfile.x64 for the rationale behind each flag.
# Note: no CPU_BASELINE/CPU_DISPATCH override for armhf — let OpenCV autodetect NEON.
RUN if [ "${PORTABLE}" = "1" ]; then \
      sed -i 's|-DBUILD_TESTS:BOOL=FALSE|-DBUILD_TESTS:BOOL=FALSE -DBUILD_LIST=core,imgproc,calib3d,features2d,flann,video,objdetect,tracking,plot,bgsegm -DWITH_FFMPEG:BOOL=OFF -DWITH_GSTREAMER:BOOL=OFF -DWITH_V4L:BOOL=OFF -DWITH_LIBV4L:BOOL=OFF -DWITH_HDF5:BOOL=OFF -DWITH_VTK:BOOL=OFF -DWITH_GDAL:BOOL=OFF -DWITH_TIFF:BOOL=OFF -DWITH_JPEG:BOOL=OFF -DWITH_PNG:BOOL=OFF -DWITH_WEBP:BOOL=OFF -DWITH_OPENEXR:BOOL=OFF -DWITH_JASPER:BOOL=OFF -DWITH_OPENJPEG:BOOL=OFF -DWITH_VA:BOOL=OFF -DWITH_VA_INTEL:BOOL=OFF -DWITH_1394:BOOL=OFF -DWITH_FREETYPE:BOOL=OFF -DWITH_GTK:BOOL=OFF -DWITH_GTK_2_X:BOOL=OFF -DWITH_QT:BOOL=OFF -DWITH_OPENGL:BOOL=OFF -DWITH_PROTOBUF:BOOL=OFF -DWITH_ADE:BOOL=OFF -DWITH_OBSENSOR:BOOL=OFF -DBUILD_opencv_hdf:BOOL=OFF -DEMGU_CV_WITH_TIFF:BOOL=FALSE -DWITH_IPP:BOOL=OFF -DWITH_OPENCL:BOOL=OFF -DWITH_LAPACK:BOOL=OFF -DWITH_TBB:BOOL=OFF -DWITH_QUIRC:BOOL=OFF -DWITH_ITT:BOOL=OFF -DBUILD_IPP_IW:BOOL=OFF -DBUILD_ITT:BOOL=OFF|' cmake_configure ; \
      sed -i 's|-DBUILD_PNG:BOOL=TRUE|-DBUILD_PNG:BOOL=FALSE|g; s|-DBUILD_JPEG:BOOL=TRUE|-DBUILD_JPEG:BOOL=FALSE|g; s|-DBUILD_TIFF:BOOL=TRUE|-DBUILD_TIFF:BOOL=FALSE|g; s|-DBUILD_WEBP:BOOL=TRUE|-DBUILD_WEBP:BOOL=FALSE|g; s|-DBUILD_JASPER:BOOL=TRUE|-DBUILD_JASPER:BOOL=FALSE|g; s|-DBUILD_OPENEXR:BOOL=TRUE|-DBUILD_OPENEXR:BOOL=FALSE|g' cmake_configure ; \
      sed -i 's|-DWITH_VTK:BOOL=TRUE|-DWITH_VTK:BOOL=FALSE|g; s|-DWITH_GSTREAMER:BOOL=TRUE|-DWITH_GSTREAMER:BOOL=FALSE|g' cmake_configure ; \
      sed -i 's|EMGU_CV_WITH_TESSERACT:BOOL=TRUE|EMGU_CV_WITH_TESSERACT:BOOL=FALSE|g; s|EMGU_CV_WITH_FREETYPE:BOOL=TRUE|EMGU_CV_WITH_FREETYPE:BOOL=FALSE|g' cmake_configure ; \
      echo "AgentDVR-minimal build: BUILD_LIST applied; FFmpeg/GStreamer/V4L/HDF5/VTK/GDAL/GeoTIFF/Tesseract/FreeType disabled." ; \
      \
      # Feature2D forward-decl fix — same as arm64/x64. \
      sed -i 's|class Feature2D {};|class Feature2D;|g' /work/emgucv/Emgu.CV.Extern/stitching/stitching_c.h ; \
      sed -i 's|class Feature2D {};|class Feature2D;|g' /work/emgucv/Emgu.CV.Extern/xfeatures2d/nonfree_c.h ; \
      # Overlay the stub core_cuda_c.cpp (see Dockerfile.x64 for rationale). \
      cp /patches/core_cuda_c.cpp.stub /work/emgucv/Emgu.CV.Extern/core/core_cuda_c.cpp ; \
      echo "Replaced Emgu.CV.Extern/core/core_cuda_c.cpp with safe stub." ; \
      # Remove imgcodecs wrapper — see Dockerfile.x64 for rationale. \
      rm -rf /work/emgucv/Emgu.CV.Extern/imgcodecs ; \
      # Patch cuda throw stubs to no-ops — see Dockerfile.x64 for rationale. \
      find /work/emgucv/Emgu.CV.Extern -type d -name 'cuda*' | while read d; do \
        for h in "$d"/*_c.h; do \
          [ -f "$h" ] || continue; \
          sed -i 's|CV_NORETURN ||g; s|CV_Error([^)]*);|/* defensive no-op */;|g' "$h"; \
        done; \
      done ; \
      # Patch OpenCV's internal throw_no_cuda() — see Dockerfile.x64 for rationale. \
      sed -i 's|CV_NORETURN void throw_no_cuda() { CV_Error([^)]*); }|void throw_no_cuda() { /* defensive no-op */ }|g' \
        /work/emgucv/opencv/modules/core/include/opencv2/core/private.cuda.hpp ; \
      echo "Patched Feature2D forward decls; removed imgcodecs wrapper; neutralized Emgu + OpenCV-internal cuda throw stubs." ; \
    fi

# The bookworm configure ends with `cmake --build . --parallel 1 --target package`.
# Replace --parallel 1 with --parallel $(nproc) and run.
#
# BuildKit cache mount: separate id per arch so caches don't collide. See Dockerfile.x64.
RUN --mount=type=cache,id=emgucv-ccache-armhf,target=/root/.ccache,sharing=locked \
    set -o pipefail ; \
    if [ -n "${JOBS}" ]; then PARALLEL="${JOBS}"; else PARALLEL="$(nproc)"; fi; \
    sed -i "s|--parallel 1|--parallel ${PARALLEL}|g" cmake_configure; \
    export MAKEFLAGS="-j${PARALLEL}"; \
    echo "=== ccache stats (before build) ===" ; ccache -s ; \
    echo "Building with PARALLEL=${PARALLEL}"; \
    bash ./cmake_configure ${BUILD_TYPE} 2>&1 | tee /tmp/emgu_build.log | tail -200 ; \
    BUILD_RC=$? ; \
    echo "=== ccache stats (after build) ===" ; ccache -s ; \
    exit $BUILD_RC

# ---- Strip + Verify -------------------------------------------------------
# Expected output path is libs/runtimes/linux-arm/native/ when IS_DEBIAN=TRUE.
# Fall back to a find-and-relocate if lsb-release detection misfires.
RUN set -e ; \
    EXPECTED=/work/emgucv/libs/runtimes/linux-arm/native ; \
    if [ ! -f "$EXPECTED/libcvextern.so" ]; then \
      FOUND="$(find /work/emgucv/libs -name libcvextern.so -type f 2>/dev/null | head -1)" ; \
      if [ -z "$FOUND" ]; then \
        echo "ERROR: libcvextern.so was not produced anywhere under /work/emgucv/libs" ; \
        find /work/emgucv -name 'libcvextern*' 2>/dev/null | head ; \
        tail -200 /tmp/emgu_build.log ; \
        exit 1 ; \
      fi ; \
      echo "NOTE: libcvextern.so was at $FOUND (not expected path $EXPECTED). Relocating." ; \
      mkdir -p "$EXPECTED" ; \
      cp -p "$FOUND" "$EXPECTED/libcvextern.so" ; \
    fi
WORKDIR /work/emgucv/libs/runtimes/linux-arm/native
RUN echo "=== SIZE BEFORE STRIP ===" && ls -lh libcvextern.so && \
    strip --strip-all libcvextern.so && \
    echo "=== SIZE AFTER STRIP ===" && ls -lh libcvextern.so
RUN set -e ; \
    file libcvextern.so ; \
    ls -lh libcvextern.so ; \
    echo "=== GLIBC SYMBOLS REQUIRED (max should be <= 2.28) ===" ; \
    MAX_GLIBC="$(nm --dynamic --undefined-only libcvextern.so | grep -oE 'GLIBC_[0-9.]+' | sort -V | uniq | tail -1)" ; \
    echo "Max GLIBC symbol: ${MAX_GLIBC}" ; \
    nm --dynamic --undefined-only libcvextern.so | grep -oE 'GLIBC_[0-9.]+' | sort -V | uniq | tail -10 ; \
    echo "=== NEEDED ENTRIES (must be whitelist-only) ===" ; \
    readelf -d libcvextern.so | grep NEEDED ; \
    \
    # Whitelist of allowed dynamic dependencies — see Dockerfile.x64 for full rationale. \
    # armhf adds libatomic.so.1 (GCC may emit __atomic_* calls on 32-bit ARM for 64-bit \
    # atomic ops that lack native instructions) — it's part of libgcc and universally present. \
    ALLOWED='^(libc\.so\.6|libdl\.so\.2|libm\.so\.6|libpthread\.so\.0|librt\.so\.1|libgcc_s\.so\.1|libstdc\+\+\.so\.6|libz\.so\.1|libatomic\.so\.1)$' ; \
    UNEXPECTED="$(readelf -d libcvextern.so | awk '/NEEDED/ {gsub(/[\[\]]/,"",$NF); print $NF}' | grep -Ev "${ALLOWED}" || true)" ; \
    if [ -n "${UNEXPECTED}" ]; then \
      echo "" ; \
      echo "!!! ERROR: libcvextern.so has unexpected runtime dependencies:" ; \
      echo "${UNEXPECTED}" | sed 's/^/    /' ; \
      echo "" ; \
      echo "These libs are NOT universally available across all target distros and will" ; \
      echo "cause 'failed to load libcvextern.so' at runtime on minimal installs." ; \
      echo "Add the corresponding -DWITH_<NAME>:BOOL=OFF flag to the cmake_configure sed" ; \
      echo "above and rebuild." ; \
      exit 1 ; \
    fi ; \
    echo "(NEEDED whitelist OK — only portable system libs)" ; \
    \
    echo "=== LDD (missing dependencies should be empty) ===" ; \
    if ldd libcvextern.so | grep "not found" ; then \
      echo "!!! ERROR: unresolved dependencies above" ; exit 1 ; \
    else \
      echo "(no missing libs)" ; \
    fi ; \
    echo "=== EXPORTED SYMBOL COUNT ===" ; \
    nm --dynamic --defined-only libcvextern.so | wc -l

FROM scratch AS export
COPY --from=builder /work/emgucv/libs/runtimes/linux-arm/native/libcvextern.so /libcvextern.so
COPY --from=builder /tmp/emgu_build.log /emgu_build.log
